# Sentry — error monitoring (get DSN from https://sentry.io → your project → Settings → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=trainer-app
# SENTRY_AUTH_TOKEN — required only for source map uploads during CI build
# SENTRY_AUTH_TOKEN=

# Neon Postgres connection string
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Session signing secret — required in production (crashes on startup if missing)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-with-node-crypto-randomBytes-32

# Admin login (browser) — email/password creates an httpOnly admin_session cookie
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-strong-password

# Optional admin API secret — still accepted via X-Admin-Secret for scripts/CI
ADMIN_SECRET=generate-a-strong-random-secret-here

# MSG91 — required for OTP SMS delivery in production
# Get these from https://control.msg91.com
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_TEMPLATE_ID=your_dlt_approved_otp_template_id_here
MSG91_INVITE_TEMPLATE_ID=your_dlt_approved_invite_sms_template_id_here

# Public app URL — used in invitation SMS links
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Firebase Cloud Messaging (HTTP v1) — Android Capacitor push
# 1) Firebase Console → add Android app with package in.trainer.fitness
# 2) Download google-services.json → android/app/google-services.json
# 3) Project settings → Service accounts → Generate new private key (JSON)
# 4) Paste the entire JSON as a single-line string below (or use BASE64 variant)
#    Tip: node -e "console.log(JSON.stringify(require('./service-account.json')))"
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional alternative if JSON env var is awkward in Vercel UI:
# FIREBASE_SERVICE_ACCOUNT_BASE64=
# Legacy FCM_SERVER_KEY is no longer used (HTTP v1 only).

# WorkoutX exercise GIF API — server-only (never expose to client)
# https://workoutxapp.com → Developer Dashboard → API key
# Used by /api/workoutx/gif/[id] proxy + scripts/seed-workoutx-media.mjs
WORKOUTX_API_KEY=

# Google Play Android Developer API (local/CI uploads — never commit the JSON key)
# Setup: docs/play-store/AUTOMATION.md
# Prefer file path for local use:
# PLAY_STORE_SERVICE_ACCOUNT_FILE=.secrets/play-store-service-account.json
# Or inline JSON for CI:
# PLAY_STORE_SERVICE_ACCOUNT_JSON=
# PLAY_PACKAGE_NAME=in.trainer.fitness
# PLAY_TRACK=internal
# PLAY_RELEASE_STATUS=completed
